NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=openprofile-be
DATABASE_SYNC=false
DATABASE_LOGGING=false
DATABASE_SSL=false



# JWT (must be at least 32 characters each)
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-to-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_SECRET=change-me-to-a-different-long-random-string-for-reset


# Misc
CORS_ORIGIN=*
SWAGGER_ENABLED=true

# Resend (transactional email)
RESEND_API_KEY=re_your_resend_api_key_here
MAIL_FROM=onboarding@resend.dev

# App URL (used in reset-password email link)
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5000

REDIS_URL=redis://localhost:6379

CLIENT_ID=your client id
CLIENT_SECRET=your client secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
