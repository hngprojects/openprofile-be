NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=openprofile-be
DATABASE_SYNC=false
DATABASE_LOGGING=false
DATABASE_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT (must be at least 32 characters each)
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-to-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=7d


# Misc
CORS_ORIGIN=*
SWAGGER_ENABLED=true

SMTP_HOST=// smtp.gmail.com,  or any other smtp host
SMTP_PORT= //465,  587
SMTP_USER=example@example.com
SMTP_PASSWORD=
SMTP_FROM= example@example.com
